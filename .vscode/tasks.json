{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "label": "npm: watch",
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\]",
          "endsPattern": "^⚡ Done in \\d+ms$"
        }
      }
    },
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "problemMatcher": []
    }
  ]
}
